
#Область ОбработчикиМетодовHTTP

Функция BarcodeResolve(Запрос)
	
	Попытка
		
		ДанныеЗапроса = ПрочитатьДанныеЗапроса(Запрос);
		Штрихкод = ШтрихкодИзДанныхЗапроса(ДанныеЗапроса);
		
		Если Штрихкод = "" Тогда
			Возврат ОтветJSON(400, Новый Структура("error,message", "invalid_request", "Не указан или некорректен штрихкод."));
		КонецЕсли;
		
		Если СтрДлина(Штрихкод) > 200 Тогда
			Возврат ОтветJSON(400, Новый Структура("error,message", "invalid_request", "Штрихкод длиннее 200 символов."));
		КонецЕсли;

		Совпадения = СовпаденияПоШтрихкоду(Штрихкод);
		
		Если Совпадения.Количество() = 0 Тогда
			Возврат ОтветJSON(200, ОтветПоиска("not_found", Штрихкод, Совпадения, "Номенклатура не найдена."));
		КонецЕсли;
		
		Если Совпадения.Количество() > 1 Тогда
			Возврат ОтветJSON(200, ОтветПоиска("ambiguous", Штрихкод, Совпадения, "Найдено несколько позиций."));
		КонецЕсли;
		
		Возврат ОтветJSON(200, ОтветПоиска("found", Штрихкод, Совпадения));
		
	Исключение
		
		Возврат ОтветJSON(500, Новый Структура("error,message", "server_error", "Ошибка сервера."));
		
	КонецПопытки;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПрочитатьДанныеЗапроса(Запрос)
	
	ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
	Если СокрЛП(ТелоЗапроса) = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЧтениеJSON = Неопределено;
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТелоЗапроса);
		ДанныеЗапроса = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Если ЧтениеJSON <> Неопределено Тогда
			ЧтениеJSON.Закрыть();
		КонецЕсли;
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат ДанныеЗапроса;
	
КонецФункции

Функция ШтрихкодИзДанныхЗапроса(ДанныеЗапроса)
	
	Если ТипЗнч(ДанныеЗапроса) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Штрихкод = "";
	Если НЕ ДанныеЗапроса.Свойство("barcode", Штрихкод) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(Штрихкод) <> Тип("Строка") Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СокрЛП(Штрихкод);
	
КонецФункции

Функция СовпаденияПоШтрихкоду(Штрихкод)
	
	ЗапросПоиска = Новый Запрос;
	ЗапросПоиска.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
	|	ШтрихкодыНоменклатуры.Номенклатура.Наименование КАК Наименование
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|	И ШтрихкодыНоменклатуры.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)";
	
	ЗапросПоиска.УстановитьПараметр("Штрихкод", Штрихкод);
	
	РезультатЗапроса = ЗапросПоиска.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Совпадения = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		Совпадения.Добавить(
			Новый Структура(
				"itemRef,name",
				Строка(Выборка.Номенклатура.УникальныйИдентификатор()),
				Выборка.Наименование));
	КонецЦикла;
	
	Возврат Совпадения;
	
КонецФункции

Функция ОтветПоиска(Статус, Штрихкод, Совпадения, Сообщение = "")
	
	Ответ = Новый Структура("status,barcode,matches", Статус, Штрихкод, Совпадения);
	Если Сообщение <> "" Тогда
		Ответ.Вставить("message", Сообщение);
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция ОтветJSON(КодСостояния, ТелоОтвета)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет));
	ЗаписатьJSON(ЗаписьJSON, ТелоОтвета);
	СтрокаОтвета = ЗаписьJSON.Закрыть();
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(СтрокаОтвета);
	
	Возврат Ответ;
	
КонецФункции

#КонецОбласти
