#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
script_path="$repo_root/scripts/quality/Invoke-QualityGate.ps1"

if command -v cygpath >/dev/null 2>&1; then
  script_path=$(cygpath -w "$script_path")
fi

if command -v pwsh >/dev/null 2>&1; then
  powershell_command=pwsh
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell_command=powershell.exe
else
  echo "PowerShell is required for the Barcode TSD pre-commit gate." >&2
  exit 1
fi

"$powershell_command" -NoProfile -ExecutionPolicy Bypass -File "$script_path" -Mode Fast -DiffMode Staged
