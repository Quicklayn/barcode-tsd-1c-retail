{
  "name": "barcode-tsd-development",
  "version": "0.0.0",
  "private": true,
  "description": "Project-local development tooling for the Barcode TSD repository",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "openspec:validate": "openspec validate --all --strict",
    "quality:fast": "pwsh -NoProfile -File ./scripts/quality/Invoke-QualityGate.ps1 -Mode Fast -DiffMode Working",
    "quality:full": "pwsh -NoProfile -File ./scripts/quality/Invoke-QualityGate.ps1 -Mode Full -DiffMode Working",
    "setup": "pwsh -NoProfile -File ./scripts/setup/Initialize-Development.ps1"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.5.0"
  }
}
